{
  "name": "Cart",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "listing_id": {
      "type": "string"
    },
    "listing_title": {
      "type": "string"
    },
    "listing_image": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "seller_email": {
      "type": "string"
    },
    "quantity": {
      "type": "number",
      "default": 1
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "required": [
    "user_email",
    "listing_id"
  ]
}